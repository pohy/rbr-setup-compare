{
  "name": "rbr-setup-compare",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "gen-schema": "pnpm dlx tsx gen-schema.ts > src/generated/setup-schema.ts",
    "gen-ranges": "pnpm dlx tsx gen-ranges.ts > src/generated/static-ranges.ts",
    "mcp:dev": "tsx src/mcp/main.ts",
    "mcp:typecheck": "tsc -p tsconfig.mcp.json --noEmit"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "lz-string": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@biomejs/biome": "2.4.10",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.29.1+sha512.48dae233635a645768a3028d19545cacc1688639eeb1f3734e42d6d6b971afbf22aa1ac9af52a173d9c3a20c15857cfa400f19994d79a2f626fcc73fccda9bbc"
}
